{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Australia Tender Discovery",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/src/run_tender_search.py",
        "--output",
        "${workspaceFolder}/output/tenders.json"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
